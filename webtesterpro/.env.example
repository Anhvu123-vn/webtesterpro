# WebTesterPro Environment Configuration
# Copy file này thành .env và chỉnh sửa các giá trị

# JWT Secret — BẮT BUỘC thay đổi trong production
SECRET_KEY=your-super-secret-key-change-in-production

# Database (SQLite mặc định)
# DATABASE_URL=sqlite:///./data/webtesterpro.db

# JWT Settings
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Cookie Security (đặt true khi dùng HTTPS)
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# SQL Debug
SQL_ECHO=false
